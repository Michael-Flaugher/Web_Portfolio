---
// Military service history gallery
// Accessible at /history
import '../styles/global.css';
---

<html lang="en">
<head>
	<meta charset="utf-8" />
	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	<meta name="viewport" content="width=device-width" />
	<title>Service History · Michael Flaugher</title>

	<style>
		* { margin: 0; padding: 0; box-sizing: border-box; }
		html { scroll-behavior: auto; }

		body {
			font-family: Arial, Helvetica, sans-serif;
			background-color: #0d1117;
			color: #c9d1d9;
			min-height: 100vh;
		}

		h1, h2, h3 { font-family: 'Arial Black', Arial, sans-serif; }

		/* == NAVBAR == */
		nav {
			display: flex;
			justify-content: space-between;
			align-items: center;
			padding: 0 32px;
			height: 58px;
			background: rgba(13,17,23,0.92);
			backdrop-filter: blur(8px);
			border-bottom: 1px solid #21262d;
			position: sticky;
			top: 0;
			z-index: 200;
		}

		.back-btn {
			display: flex;
			align-items: center;
			gap: 8px;
			background: none;
			border: 1px solid #30363d;
			border-radius: 8px;
			padding: 7px 14px;
			color: #c9d1d9;
			font-size: 0.82rem;
			font-weight: 700;
			font-family: Arial, sans-serif;
			cursor: pointer;
			text-decoration: none;
			transition: border-color 0.2s, color 0.2s;
		}
		.back-btn:hover { border-color: #388bfd80; color: #e6edf3; }

		/* == FLAG HERO HEADER == */
		.hero-header {
			position: relative;
			background-image: url('/American_Flag.jpg');
			background-size: cover;
			background-position: center;
			padding: 64px 24px;
			text-align: center;
		}
		.hero-header::before {
			content: '';
			position: absolute;
			inset: 0;
			background: rgba(13,17,23,0.72);
		}
		.hero-header > * { position: relative; z-index: 1; }

		/* == GALLERY GRID == */
		.gallery-wrap {
			max-width: 720px;
			margin: 0 auto;
			padding: 40px 24px 60px;
			display: grid;
			grid-template-columns: repeat(2, 1fr);
			gap: 24px;
		}
		@media (max-width: 560px) {
			.gallery-wrap { grid-template-columns: 1fr; }
		}

		/* == GALLERY CARD == */
		.gallery-card {
			background: #161b22;
			border: 1px solid #21262d;
			border-radius: 14px;
			overflow: hidden;
			box-shadow: 0 4px 24px rgba(0,0,0,0.3);
			transition: border-color 0.2s, transform 0.2s;
		}
		.gallery-card:hover {
			border-color: #388bfd60;
			transform: translateY(-2px);
		}

		.gallery-card img {
			width: 100%;
			aspect-ratio: 4/3;
			object-fit: cover;
			display: block;
			background: #1c2128;
		}

		.gallery-card-body {
			padding: 16px;
		}

		.gallery-card-title {
			font-size: 0.72rem;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 0.1em;
			color: #58a6ff;
			margin-bottom: 8px;
		}

		.gallery-card-caption {
			font-size: 0.88rem;
			line-height: 1.7;
			color: #8b949e;
			min-height: 40px;
		}

		/* == SECTION DIVIDER == */
		.section-label {
			max-width: 720px;
			margin: 0 auto;
			padding: 0 24px;
		}
		.section-label h2 {
			font-size: 0.7rem;
			text-transform: uppercase;
			letter-spacing: 0.14em;
			color: #58a6ff;
			margin-bottom: 8px;
			font-weight: 700;
		}
		.section-label .divider {
			width: 300px;
			height: 2px;
			background: linear-gradient(90deg, #388bfd, transparent);
			border-radius: 2px;
			margin-bottom: 0;
		}
	</style>
</head>

<body>

	<!-- == NAVBAR == -->
	<nav>
		<a href="/" class="back-btn">← Back to Portfolio</a>
		<span style="font-size:0.85rem;font-weight:700;color:#8b949e;font-family:'Arial Black',Arial,sans-serif;">Service History</span>
	</nav>

	<!-- == HERO == -->
	<div class="hero-header">
		<img src="/Army_Insignia.png" alt="U.S. Army" style="width:80px;height:80px;object-fit:contain;margin:0 auto 20px;display:block;filter:drop-shadow(0 4px 12px rgba(0,0,0,0.6));" />
		<p style="font-size:0.78rem;text-transform:uppercase;letter-spacing:0.14em;color:#58a6ff;margin-bottom:10px;font-weight:700;">U.S. Army Veteran</p>
		<h1 style="font-size:2rem;font-weight:900;color:#e6edf3;line-height:1.1;margin-bottom:12px;">Service History</h1>
		<p style="font-size:0.95rem;color:#c9d1d9;max-width:480px;margin:0 auto;">Awards, records, and highlights from my time in service.</p>
	</div>

	<!-- == AWARDS == -->
	<div class="section-label" style="padding-top:40px;">
		<h2>Awards</h2>
		<div class="divider"></div>
	</div>

	<div class="gallery-wrap" style="padding-top:24px;">

		<div class="gallery-card">
			<img src="/ARCOM_12SEP2024.jpg" alt="ARCOM September 2024" />
			<div class="gallery-card-body">
				<p class="gallery-card-title">ARCOM · Sep 2024</p>
				<p class="gallery-card-caption"></p>
			</div>
		</div>

		<div class="gallery-card">
			<img src="/ARCOM_24APR2024.jpg" alt="ARCOM April 2024" />
			<div class="gallery-card-body">
				<p class="gallery-card-title">ARCOM · Apr 2024</p>
				<p class="gallery-card-caption"></p>
			</div>
		</div>

		<div class="gallery-card">
			<img src="/ARCOM_29FEB2024.jpg" alt="ARCOM February 2024" />
			<div class="gallery-card-body">
				<p class="gallery-card-title">ARCOM · Feb 2024</p>
				<p class="gallery-card-caption"></p>
			</div>
		</div>

		<div class="gallery-card">
			<img src="/AAM_07MAY2023.jpg" alt="AAM May 2023" />
			<div class="gallery-card-body">
				<p class="gallery-card-title">AAM · May 2023</p>
				<p class="gallery-card-caption"></p>
			</div>
		</div>

		<div class="gallery-card">
			<img src="/AAM_24FEB2023.jpg" alt="AAM February 2023" />
			<div class="gallery-card-body">
				<p class="gallery-card-title">AAM · Feb 2023</p>
				<p class="gallery-card-caption"></p>
			</div>
		</div>

		<div class="gallery-card">
			<img src="/COA_10MAR2021.jpg" alt="Certificate of Achievement" />
			<div class="gallery-card-body">
				<p class="gallery-card-title">Certificate of Achievement · Mar 2021</p>
				<p class="gallery-card-caption"></p>
			</div>
		</div>

	</div>

	<!-- == TRAINING & SERVICE == -->
	<div class="section-label">
		<h2>Training &amp; Service</h2>
		<div class="divider"></div>
	</div>

	<div class="gallery-wrap" style="padding-top:24px;">

		<div class="gallery-card">
			<img src="/BLC_29SEP2022.jpg" alt="Basic Leader Course" />
			<div class="gallery-card-body">
				<p class="gallery-card-title">Basic Leader Course · Sep 2022</p>
				<p class="gallery-card-caption"></p>
			</div>
		</div>

		<div class="gallery-card">
			<img src="/BCT_09MAY2019.jpg" alt="Basic Combat Training" />
			<div class="gallery-card-body">
				<p class="gallery-card-title">Basic Combat Training · May 2019</p>
				<p class="gallery-card-caption"></p>
			</div>
		</div>

		<div class="gallery-card">
			<img src="/Affiliation_30SEP2019.jpg" alt="Affiliation" />
			<div class="gallery-card-body">
				<p class="gallery-card-title">Affiliation · Sep 2019</p>
				<p class="gallery-card-caption"></p>
			</div>
		</div>

		<div class="gallery-card">
			<img src="/Kuwait.jpg" alt="Kuwait Deployment" />
			<div class="gallery-card-body">
				<p class="gallery-card-title">Kuwait Deployment</p>
				<p class="gallery-card-caption"></p>
			</div>
		</div>

		<div class="gallery-card">
			<img src="/Diploma_30SEP2019.jpg" alt="Diploma" />
			<div class="gallery-card-body">
				<p class="gallery-card-title">Diploma · Sep 2019</p>
				<p class="gallery-card-caption"></p>
			</div>
		</div>

	</div>

	<!-- == FOOTER == -->
	<footer style="border-top:1px solid #21262d;text-align:center;padding:24px;font-size:0.8rem;color:#484f58;">
		© 2026 Michael Flaugher · Built with Astro
	</footer>

</body>
</html>
