	<script is:inline>

		function toggleMenu() {
			document.getElementById('hamburger').classList.toggle('open');
			document.getElementById('nav-menu').classList.toggle('open');
		}

		document.addEventListener('click', function(e) {
			const btn  = document.getElementById('hamburger');
			const menu = document.getElementById('nav-menu');
			if (!btn.contains(e.target) && !menu.contains(e.target)) {
				btn.classList.remove('open');
				menu.classList.remove('open');
			}
		});

		function navTo(sectionId) {
			document.getElementById('hamburger').classList.remove('open');
			document.getElementById('nav-menu').classList.remove('open');

			const section = document.getElementById(sectionId);
			if (!section) return;

			const card       = section.querySelector('.card') || section;
			const cardTop    = card.getBoundingClientRect().top + window.pageYOffset;
			const cardHeight = card.offsetHeight;
			const navHeight  = 58;
			const available  = window.innerHeight - navHeight;

			// Tall cards: snap to top. Short cards: center in viewport.
			let scrollTo;
			if (cardHeight > available) {
				scrollTo = cardTop - navHeight - 16;
			} else {
				scrollTo = cardTop - (window.innerHeight / 2) + (cardHeight / 2);
			}

			const startY    = window.pageYOffset;
			const distance  = Math.max(0, scrollTo) - startY;
			const duration  = 900;
			const startTime = performance.now();

			(function scrollStep(now) {
				const elapsed = now - startTime;
				const t       = Math.min(elapsed / duration, 1);
				const eased   = t < 0.5 ? 4*t*t*t : 1 - Math.pow(-2*t+2, 3)/2;
				window.scrollTo(0, startY + distance * eased);
				if (t < 1) requestAnimationFrame(scrollStep);
			})(performance.now());

			setTimeout(function() {
				card.classList.remove('flash');
				void card.offsetWidth;
				card.classList.add('flash');
			}, 700);
		}

	</script>

