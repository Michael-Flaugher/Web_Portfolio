// FRONTMATTER — server-side logic, imports, and variables go here.
// Currently only importing our global Tailwind CSS file.
import '../styles/global.css';
---

<html lang="en">
<head>
	<!-- == HEAD — invisible page settings == -->

	<!-- UTF-8 encoding — supports all characters and emojis -->
	<meta charset="utf-8" />
	<!-- Small icon shown in the browser tab -->
	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	<!-- Scales the page correctly on phones and tablets -->
	<meta name="viewport" content="width=device-width" />
	<!-- Astro auto-fills its version here — leave this alone -->
	<meta name="generator" content={Astro.generator} />
	<!-- Text shown in the browser tab -->
	<title>Michael Flaugher</title>

	<!-- Google Fonts — preconnect speeds up font loading.
	     Sora = headings | Inter = body text -->
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;600;700&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />

	<style>
		/* == RESET — remove browser default spacing for a clean slate.
		   box-sizing: border-box = padding included in width calculations. == */
		* { margin: 0; padding: 0; box-sizing: border-box; }

		/* == BODY — base styles for the whole page == */
		body {
			font-family: 'Inter', sans-serif;
			background-color: #0d1117; /* dark navy background */
			color: #c9d1d9;            /* default text color */
			min-height: 100vh;         /* always full screen height */
		}

		/* == HEADINGS — use Sora for visual hierarchy == */
		h1, h2, h3, nav span { font-family: 'Sora', sans-serif; }

		/* == SMOOTH SCROLL — nav links animate instead of jumping == */
		html { scroll-behavior: smooth; }

		/* == CARD — reusable raised surface. Add class="card" to any element. == */
		.card {
			background: #161b22;
			border: 1px solid #21262d;
			border-radius: 14px;
			box-shadow: 0 4px 24px rgba(0,0,0,0.3);
		}

		/* == BADGE — each credential tile.
		   flex-direction: column stacks logo, text, and link vertically. == */
		.badge {
			display: flex;
			flex-direction: column;
			align-items: center;
			justify-content: center;
			gap: 8px;
			padding: 20px 12px;
			background: #1c2128;
			border: 2px solid #30363d;
			border-radius: 12px;
			font-size: 0.75rem;
			font-weight: 750;
			color: #8b949e;
			transition: all 0.2s;
			text-align: center;
		}
		/* Badge logo size */
		.badge img { width: 64px; height: 64px; }
		/* Blue glow on hover — 60 suffix = 37% opacity */
		.badge:hover {
			border-color: #388bfd60;
			color: #c9d1d9;
			background: #1f2937;
		}

		/* == MODAL OVERLAY — full screen dark backdrop behind popups == */
		.modal-overlay {
			display: none;        /* hidden until badge is clicked */
			position: fixed;      /* stays in place while scrolling */
			inset: 0;             /* covers the entire screen */
			background: rgba(0,0,0,0.75);
			z-index: 999;         /* sits above everything else */
			align-items: center;
			justify-content: center;
		}
		/* == MODAL BOX — the actual popup container == */
		.modal-box {
			background: #161b22;
			border: 1px solid #30363d;
			border-radius: 16px;
			padding: 36px;
			width: 100%;
			max-width: 420px;
			margin: 24px;
			position: relative;
		}
		/* == MODAL CLOSE — X button in top right corner == */
		.modal-close {
			position: absolute;
			top: 14px;
			right: 16px;
			background: none;
			border: none;
			color: #8b949e;
			font-size: 1.1rem;
			cursor: pointer;
			line-height: 1;
		}
		.modal-close:hover { color: #e6edf3; }

		/* == MODAL BUTTON — View Certificate / Learn More buttons == */
		.modal-btn {
			padding: 8px 20px;
			border-radius: 8px;
			text-decoration: none;
			font-size: 0.85rem;
			font-weight: 500;
		}

		/* == SECTION TITLE — small uppercase label above each section == */
		.section-title {
			font-size: 0.7rem;
			text-transform: uppercase;
			letter-spacing: 0.14em;
			color: #58a6ff;
			margin-bottom: 8px;
			font-family: 'Inter', sans-serif;
			font-weight: 500;
		}

		/* == DIVIDER — blue accent line under section titles.
		   Fades from blue to transparent left to right. == */
		.divider {
			width: 300px;
			height: 2px;
			background: linear-gradient(90deg, #388bfd, transparent);
			border-radius: 2px;
			margin-bottom: 24px;
		}

		/* == SOCIAL LINK — each row in the Connect section.
		   flex lines up icon, text, and arrow horizontally. == */
		.social-link {
			display: flex;
			align-items: center;
			gap: 14px;
			padding: 16px 20px;
			background: #161b22;
			border: 2px solid #21262d;
			border-radius: 12px;
			text-decoration: none; /* removes default underline */
			color: #c9d1d9;
			transition: all 0.2s;
		}
		/* Lifts card 2px and adds blue glow on hover */
		.social-link:hover {
			border-color: #388bfd60;
			background: #1c2128;
			transform: translateY(-2px);
			box-shadow: 0 6px 20px rgba(56,139,253,0.08);
		}
		/* Square icon container on the left of each social link */
		.social-icon {
			width: 40px;
			height: 40px;
			border-radius: 10px;
			display: flex;
			align-items: center;
			justify-content: center;
			flex-shrink: 0; /* prevents shrinking in tight spaces */
		}
	</style>
</head>

<body>

	<!-- == NAVBAR — sticky, stays at top while scrolling == -->
