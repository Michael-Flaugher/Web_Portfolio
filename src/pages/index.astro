		<!-- Name and email stacked vertically -->
		<div style="display: flex; flex-direction: column; gap: 2px;">
			<span style="font-size: 1rem; font-weight: 600; color: #e6edf3;">Michael Flaugher</span>
			<span style="font-size: 0.75rem; color: #8b949e;">flaugher111413@gmail.com</span>
		</div>
	</nav>

	<!-- == HERO — first thing visitors see == -->
	<section id="about" style="
		padding: 80px 24px;
		text-align: center;
		max-width: 640px;
		margin: 0 auto;
