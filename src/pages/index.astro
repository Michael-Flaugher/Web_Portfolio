	<!-- No external fonts — Arial renders sharply on all systems -->

	<style>
		/* == RESET == */
		* { margin: 0; padding: 0; box-sizing: border-box; }

		/* == BODY — Arial for crisp, sharp rendering == */
		body {
			font-family: Arial, Helvetica, sans-serif;
			background-color: #0d1117;
			color: #c9d1d9;
			min-height: 100vh;
		}

		/* == HEADINGS — Arial Black for maximum weight and sharpness == */
		h1, h2, h3 { font-family: 'Arial Black', Arial, sans-serif; }

		/* == SMOOTH SCROLL == */
		html { scroll-behavior: smooth; }

		/* == CARD == */
		.card {
			background: #161b22;
			border: 1px solid #21262d;
			border-radius: 14px;
			box-shadow: 0 4px 24px rgba(0,0,0,0.3);
		}

		/* == BADGE GRID — 3 cols desktop, 2 cols mobile == */
		.badge-grid {
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			gap: 16px;
		}
		@media (max-width: 480px) {
			.badge-grid { grid-template-columns: repeat(2, 1fr); }
		}

		/* == BADGE == */
		.badge {
			display: flex;
			flex-direction: column;
			align-items: center;
			justify-content: center;
			gap: 8px;
			padding: 20px 12px;
			background: #1c2128;
			border: 2px solid #30363d;
			border-radius: 12px;
			font-size: 0.75rem;
			font-weight: 700;
			color: #8b949e;
			transition: all 0.2s;
			text-align: center;
			cursor: pointer;
		}
		.badge img { width: 64px; height: 64px; }
		.badge:hover { border-color: #388bfd60; color: #c9d1d9; background: #1f2937; }

		/* == MODAL OVERLAY == */
		.modal-overlay {
			display: none;
			position: fixed;
			inset: 0;
			background: rgba(0,0,0,0.75);
			z-index: 999;
			align-items: center;
			justify-content: center;
		}
		.modal-box {
			background: #161b22;
			border: 1px solid #30363d;
			border-radius: 16px;
			padding: 36px;
			width: 100%;
			max-width: 420px;
			margin: 24px;
			position: relative;
		}
		.modal-close {
			position: absolute;
			top: 14px; right: 16px;
			background: none; border: none;
			color: #8b949e; font-size: 1.1rem; cursor: pointer;
		}
		.modal-close:hover { color: #e6edf3; }
		.modal-btn {
			padding: 8px 20px;
			border-radius: 8px;
			text-decoration: none;
			font-size: 0.85rem;
			font-weight: 600;
			font-family: Arial, sans-serif;
		}

		/* == SECTION TITLE == */
		.section-title {
			font-size: 0.7rem;
			text-transform: uppercase;
			letter-spacing: 0.14em;
			color: #58a6ff;
			margin-bottom: 8px;
			font-family: Arial, sans-serif;
			font-weight: 700;
		}

		/* == DIVIDER == */
		.divider {
			width: 300px;
			height: 2px;
			background: linear-gradient(90deg, #388bfd, transparent);
			border-radius: 2px;
			margin-bottom: 24px;
		}

		/* == SOCIAL LINK == */
		.social-link {
			display: flex;
			align-items: center;
			gap: 14px;
			padding: 16px 20px;
			background: #161b22;
			border: 2px solid #21262d;
			border-radius: 12px;
			text-decoration: none;
			color: #c9d1d9;
			transition: all 0.2s;
		}
		.social-link:hover {
			border-color: #388bfd60;
			background: #1c2128;
			transform: translateY(-2px);
			box-shadow: 0 6px 20px rgba(56,139,253,0.08);
		}
		.social-icon {
			width: 40px; height: 40px;
			border-radius: 10px;
			display: flex; align-items: center; justify-content: center;
			flex-shrink: 0;
		}

		/* ============================================================
		   NAVBAR
		   ============================================================ */
		nav {
			display: flex;
			justify-content: space-between;
			align-items: center;
			padding: 0 32px;
			height: 58px;
			background: #0d1117;
			border-bottom: 1px solid #21262d;
			position: sticky;
			top: 0;
			z-index: 200;
		}

		/* == HAMBURGER BUTTON — 3 horizontal lines == */
		.hamburger {
			background: none;
			border: 1px solid #30363d;
			border-radius: 8px;
			padding: 8px 10px;
			cursor: pointer;
			display: flex;
			flex-direction: column;
			gap: 5px;
			transition: border-color 0.2s;
		}
		.hamburger:hover { border-color: #388bfd80; }
		.hamburger span {
			display: block;
			width: 20px;
			height: 2px;
			background: #c9d1d9;
			border-radius: 2px;
			transition: all 0.25s ease;
		}
		/* Animate into X when open */
		.hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
		.hamburger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
		.hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

		/* == DROPDOWN MENU == */
		.nav-menu {
			display: none;
			position: absolute;
			top: 66px;
			right: 24px;
			background: #161b22;
			border: 1px solid #30363d;
			border-radius: 12px;
			padding: 8px;
			min-width: 210px;
			box-shadow: 0 8px 32px rgba(0,0,0,0.6);
			z-index: 300;
		}
		.nav-menu.open { display: block; }

		.nav-menu a {
			display: flex;
			align-items: center;
			gap: 12px;
			padding: 10px 14px;
			color: #c9d1d9;
			text-decoration: none;
			border-radius: 8px;
			font-size: 0.88rem;
			font-weight: 700;
			font-family: Arial, sans-serif;
			transition: background 0.15s;
		}
		.nav-menu a:hover { background: #1c2128; color: #e6edf3; }
		.nav-icon { width: 22px; text-align: center; font-style: normal; }

		/* ============================================================
		   SECTION FLASH — faint white border glow when nav link is clicked
		   ============================================================ */
		@keyframes sectionFlash {
			0%   { box-shadow: 0 4px 24px rgba(0,0,0,0.3); }
			20%  { box-shadow: 0 0 0 3px rgba(255,255,255,0.28),
			                   0 4px 32px rgba(56,139,253,0.3); }
			100% { box-shadow: 0 4px 24px rgba(0,0,0,0.3); }
		}
		.flash { animation: sectionFlash 0.85s ease forwards; }
	</style>
</head>

